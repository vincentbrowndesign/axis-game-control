{
  "version": "1.0",
  "inputs": [
    {
      "type": "WorkflowImage",
      "name": "image"
    },
    {
      "type": "WorkflowParameter",
      "name": "model_id",
      "default_value": "rfdetr-small"
    }
  ],
  "steps": [
    {
      "type": "roboflow_core/roboflow_object_detection_model@v1",
      "name": "rf_detr",
      "images": "$inputs.image",
      "model_id": "$inputs.model_id",
      "class_agnostic_nms": false,
      "confidence": 0.35,
      "max_detections": 64
    },
    {
      "type": "roboflow_core/trackers_bytetrack@v1",
      "name": "bytetrack",
      "image": "$inputs.image",
      "detections": "$steps.rf_detr.predictions",
      "minimum_iou_threshold": 0.1,
      "minimum_consecutive_frames": 2,
      "lost_track_buffer": 30,
      "track_activation_threshold": 0.35,
      "high_conf_det_threshold": 0.45
    },
    {
      "type": "AxisOpenCvOverlay",
      "name": "axis_overlay",
      "image": "$inputs.image",
      "tracked_detections": "$steps.bytetrack.tracked_detections"
    }
  ],
  "outputs": [
    {
      "type": "JsonField",
      "name": "annotated_image",
      "selector": "$steps.axis_overlay.annotated_image"
    },
    {
      "type": "JsonField",
      "name": "overlay_payload",
      "selector": "$steps.axis_overlay.overlay_payload"
    }
  ]
}
